{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WebP Converter",
  "version": "0.1.0",
  "identifier": "com.webpconverter.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "WebP Converter",
        "width": 720,
        "height": 640,
        "minWidth": 560,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/cwebp"],
    "category": "Utility",
    "shortDescription": "Bulk-convert images to WebP",
    "longDescription": "Drop a folder of images and get a folder of optimized WebP files. PNGs are encoded losslessly to preserve transparency; everything else uses a tunable quality slider. Bundles Google's official cwebp encoder so end users install nothing."
  }
}
